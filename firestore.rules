rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function hasOnlyAllowedUserFields(data) {
      return data.keys().hasOnly([
        'uid',
        'email',
        'displayName',
        'photoURL',
        'createdAt',
        'updatedAt',
        'subscribed',
        'plan',
        'billingCycle',
        'nextPaymentDate',
        'cardLast4',
        'cardBrand',
        'status'
      ]);
    }

    function hasLockedEntitlementDefaults(data) {
      return data.subscribed == false &&
             data.plan == null &&
             data.billingCycle == null &&
             data.nextPaymentDate == null &&
             data.cardLast4 == null &&
             data.cardBrand == null &&
             data.status in ['inactive', 'canceled'];
    }

    function isValidUserAccount(data) {
      return hasOnlyAllowedUserFields(data) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256 &&
             (data.displayName == null || (data.displayName is string && data.displayName.size() <= 128)) &&
             (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 512)) &&
             (data.createdAt is timestamp || data.createdAt is string) &&
             (data.updatedAt == null || data.updatedAt is timestamp || data.updatedAt is string) &&
             data.subscribed is bool &&
             data.plan == null &&
             data.billingCycle == null &&
             data.nextPaymentDate == null &&
             data.cardLast4 == null &&
             data.cardBrand == null &&
             data.status is string && data.status.size() <= 16 && data.status in ['inactive', 'canceled'] &&
             hasLockedEntitlementDefaults(data);
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && isEmailVerified() && isValidUserAccount(incoming());
      allow update: if false;
      allow delete: if false;
    }

    function isValidViewerProfile(data) {
      return data.keys().hasOnly(['name', 'avatar', 'isKids', 'watchlist', 'createdAt', 'updatedAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 64 &&
             data.avatar is string && data.avatar.size() <= 128 &&
             data.isKids is bool &&
             data.watchlist is list && data.watchlist.size() <= 100 &&
             (data.createdAt is timestamp || data.createdAt is string) &&
             (data.updatedAt == null || data.updatedAt is timestamp || data.updatedAt is string);
    }

    match /users/{userId}/profiles/{profileId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && isEmailVerified() && isValidId(profileId) && isValidViewerProfile(incoming());
      allow update: if isOwner(userId) && isEmailVerified() && isValidId(profileId) && isValidViewerProfile(incoming()) && incoming().createdAt == existing().createdAt;
      allow delete: if isOwner(userId) && isEmailVerified();
    }
  }
}
